{
    "name": "api-analytics/symfony",
    "description": "API Analytics middleware for Symfony applications.",
    "keywords": ["analytics", "api", "monitoring", "symfony", "middleware"],
    "license": "MIT",
    "authors": [
        {
            "name": "Tom Draper",
            "email": "tomjdraper1@gmail.com"
        }
    ],
    "homepage": "https://github.com/tom-draper/api-analytics-php-symfony",
    "require": {
        "php": "^8.0",
        "symfony/http-kernel": "^5.4 || ^6.0 || ^7.0",
        "symfony/http-foundation": "^5.4 || ^6.0 || ^7.0",
        "symfony/event-dispatcher": "^5.4 || ^6.0 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0 || ^11.0",
        "symfony/http-kernel": "^5.4 || ^6.0 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "ApiAnalytics\\Symfony\\": "src/",
            "ApiAnalytics\\Core\\": "src/Core/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApiAnalytics\\Symfony\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
